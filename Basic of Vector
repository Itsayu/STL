#include <bits/stdc++.h>
using namespace std;

void explainVector(){
  vector<int> v;
  v.push_back(95);
  v.push_back(9);
  v.push_back(5);
  cout<<v[0]<<", "<<v[1]<<", "<<v[2]<<endl;
}

void vectorPair(){
  vector<pair<string, int>> v;
  v.push_back({"Iti", 995});
  v.push_back({"Ayu", 195});
  cout<<v[0].first<<endl;
  cout<<v[0].second<<endl;
  cout<<v[1].first<<endl;
  cout<<v[1].second<<endl;
}

void vectorRule(){
  vector<int> v(5, 95); //[95, 95, 95, 95, 95]
  cout<<v[0]<<", "<<v[1]<<", "<<v[2]<<", "<<v[3]<<", "<<v[4]<<", "<<v[5]<<endl;
}


void vectorCopy(){
  vector<int> v1(5, 995);
  cout<<v1[0]<<", "<<v1[1]<<", "<<v1[2]<<", "<<v1[3]<<", "<<v1[4]<<", "<<v1[5]<<endl;
  
  vector<int> v2(v1);
  cout<<v2[0]<<", "<<v2[1]<<", "<<v2[2]<<", "<<v2[3]<<", "<<v2[4]<<", "<<v2[5]<<endl;
}


int main() 
{
    explainVector();
    vectorPair();
    vectorRule();
    vectorCopy();
    return 0;
}
